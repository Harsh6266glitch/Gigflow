# ==========================================
# GigFlow CRM Environment Configuration Example
# ==========================================

# ------------------------------------------
# Backend Config (.env should be placed in backend/)
# ------------------------------------------
# Port for the Node/Express backend server
PORT=5000

# MongoDB URI (MongoDB Atlas string or local MongoDB instance)
# If left blank, the app will fallback to an In-Memory DB for testing automatically.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/gigflow?retryWrites=true&w=majority

# Secret key used for signing JSON Web Tokens (JWT)
JWT_SECRET=your_cryptographically_secure_random_secret_string

# Expiration time for JWT tokens
JWT_EXPIRES_IN=7d

# Node environment state (development, production)
NODE_ENV=development

# Allowed client URL for CORS origin checking (production frontend URL or local dev url)
CLIENT_URL=http://localhost:5173

# ------------------------------------------
# Frontend Config (.env should be placed in frontend/)
# ------------------------------------------
# Base URL for the backend API (without trailing slash)
VITE_API_URL=http://localhost:5000/api
